# Mathe-Quiz local Docker Compose template
# Copy to .env and replace the placeholder secrets before first start.

NODE_ENV=development
WEB_PORT=3031
API_PORT=3032
VALIDATOR_INTERNAL_PORT=8001

POSTGRES_DB=mathe_quiz
POSTGRES_USER=mathe_user
POSTGRES_PASSWORD=<set-local-db-password>
JWT_SECRET=<set-local-jwt-secret>

FRONTEND_ORIGIN=http://localhost:3031
VALIDATOR_URL=http://validator:8001
VITE_API_BASE_URL=http://localhost:3032

VITE_LEGAL_NAME=
VITE_LEGAL_EMAIL=
VITE_LEGAL_ADDRESS_LINE_1=
VITE_LEGAL_ADDRESS_LINE_2=
VITE_LEGAL_COUNTRY=Deutschland
VITE_LEGAL_CONTENT_RESPONSIBLE=
