# Mathe-Quiz production Docker Compose template
# Copy to .env.production and replace every placeholder before deployment.

NODE_ENV=production
WEB_PORT=3041
API_PORT=3042
VALIDATOR_INTERNAL_PORT=8001

POSTGRES_DB=mathe_quiz
POSTGRES_USER=mathe_user
POSTGRES_PASSWORD=<set-strong-postgres-password>
JWT_SECRET=<set-long-random-jwt-secret>

FRONTEND_ORIGIN=https://mathe-quiz.elmarhepp.de
VALIDATOR_URL=http://validator:8001
VITE_API_BASE_URL=https://mathe-quiz-api.elmarhepp.de

VITE_LEGAL_NAME=<set-legal-name>
VITE_LEGAL_EMAIL=<set-legal-email>
VITE_LEGAL_ADDRESS_LINE_1=<set-legal-address-line-1>
VITE_LEGAL_ADDRESS_LINE_2=<set-legal-address-line-2>
VITE_LEGAL_COUNTRY=Deutschland
VITE_LEGAL_CONTENT_RESPONSIBLE=<set-legal-content-responsible>
