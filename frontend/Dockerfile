FROM node:20-alpine AS builder

WORKDIR /app

ARG VITE_API_BASE_URL
ARG VITE_LEGAL_NAME
ARG VITE_LEGAL_EMAIL
ARG VITE_LEGAL_ADDRESS_LINE_1
ARG VITE_LEGAL_ADDRESS_LINE_2
ARG VITE_LEGAL_COUNTRY
ARG VITE_LEGAL_CONTENT_RESPONSIBLE

ENV VITE_API_BASE_URL=$VITE_API_BASE_URL
ENV VITE_LEGAL_NAME=$VITE_LEGAL_NAME
ENV VITE_LEGAL_EMAIL=$VITE_LEGAL_EMAIL
ENV VITE_LEGAL_ADDRESS_LINE_1=$VITE_LEGAL_ADDRESS_LINE_1
ENV VITE_LEGAL_ADDRESS_LINE_2=$VITE_LEGAL_ADDRESS_LINE_2
ENV VITE_LEGAL_COUNTRY=$VITE_LEGAL_COUNTRY
ENV VITE_LEGAL_CONTENT_RESPONSIBLE=$VITE_LEGAL_CONTENT_RESPONSIBLE

COPY package*.json ./
COPY frontend/package*.json ./frontend/

RUN npm ci --workspace=frontend

COPY frontend ./frontend

WORKDIR /app/frontend
RUN npm run build

FROM nginx:1.27-alpine

COPY frontend/nginx.conf /etc/nginx/conf.d/default.conf
COPY --from=builder /app/frontend/dist /usr/share/nginx/html

EXPOSE 80

CMD ["nginx", "-g", "daemon off;"]
